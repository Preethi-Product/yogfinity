# Database (Vercel Postgres / Neon) — required for permanent booking storage.
# In Vercel: Project → Storage → Create Database → Postgres → Connect to Project.
# Vercel auto-injects POSTGRES_URL (and related vars). For local dev, copy those
# values from the Vercel dashboard into .env.local.
POSTGRES_URL=postgres://user:password@host/db?sslmode=require

# Email delivery (Resend) — required for booking confirmation emails.
# 1. Sign up at https://resend.com (free tier: 100 emails/day, 3,000/month)
# 2. Create an API key at https://resend.com/api-keys
# 3. (Optional) Verify a domain at https://resend.com/domains so you can
#    use a branded From address. Without a verified domain you must keep
#    RESEND_FROM as the default and emails can only be sent to the address
#    that owns the Resend account.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: branded sender once a domain is verified on Resend.
# Default: "YOGFINITY <onboarding@resend.dev>"
RESEND_FROM="YOGFINITY <hello@yogfinity.com>"
